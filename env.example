# Copy to .env (gitignored) and fill in real values:
#   cp .env.example .env
#
# The extraction worker mounts this .env and RE-READS it on every job, so
# switching LLMs is live: edit a value below and the next extraction uses it —
# no rebuild, no restart. (Editing values consumed by the backend/worker at
# boot — e.g. OLLAMA_BASE_URL — still benefits from `docker compose up -d`.)

# --- LLM provider for the extraction service ---
# ollama (default, local) | claude | openai
LLM_PROVIDER=ollama

# Claude (Anthropic) — required when LLM_PROVIDER=claude.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI — required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local) — used when LLM_PROVIDER=ollama.
# From inside Docker, reach a host-run Ollama via host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
