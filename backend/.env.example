# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Local file storage (no S3) — audio/image uploads land here
UPLOADS_DIR=uploads

# Database (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=toeic
DB_PASSWORD=toeic
DB_NAME=toeic

# Auth (REQ: JWT HS256 access + refresh)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL_DAYS=7

# Default admin seed (npm run seed:admin) — change the password after first login
ADMIN_EMAIL=admin@toeic.local
ADMIN_PASSWORD=Admin12345
ADMIN_DISPLAY_NAME=Administrator

# Social login (frontend token -> backend verify). Leave blank to disable.
# Google: create an OAuth Web client at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Facebook: create an app at https://developers.facebook.com/apps (App ID + Secret)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Question extraction (Redis queue + Python worker)
REDIS_URL=redis://localhost:6379/0
EXTRACTION_QUEUE=extraction:jobs
# Shared secret between NestJS and the Python extraction worker (internal endpoints)
INTERNAL_API_TOKEN=dev-internal-token-change-me

# Password reset email. Frontend base URL used to build the reset link:
APP_BASE_URL=http://localhost:5173
MAIL_FROM=TOEIC Platform <no-reply@toeic.local>
# SMTP (any provider: SES / SendGrid / Resend / Mailgun). Leave SMTP_HOST blank
# to log reset links to the backend console instead of sending real email (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
