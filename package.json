{
  "name": "toeic-app",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "TOEIC learning platform - monorepo (NestJS backend + React frontend)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "backend:dev": "npm run start:dev --workspace backend",
    "frontend:dev": "npm run dev --workspace frontend",
    "migration:run": "npm run migration:run --workspace backend",
    "seed:admin": "npm run seed:admin --workspace backend"
  },
  "engines": {
    "node": ">=20"
  }
}
